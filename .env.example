# Server
PORT=5000

# MySQL (Aiven)
DB_HOST=
DB_PORT=
DB_USER=
DB_PASS=
DB_NAME=
# Path to Aiven CA certificate (download ca.pem from Aiven console)
DB_SSL_CA_PATH=
# Or paste CA certificate contents (use \n for line breaks)
DB_SSL_CA=

# JWT Authentication
JWT_SECRET=

# Cloudinary (File Uploads)
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# Allowed email domain for student registration (e.g. college.edu)
ALLOWED_EMAIL_DOMAIN=

# CORS - comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
